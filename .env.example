# Configurações do OpenRouter (Obrigatório para resumos via IA)
# Crie uma conta no OpenRouter.ai, gere sua key e cole aqui:
OPENROUTER_API_KEY="sk-or-v1-coloque-sua-chave-aqui"

# Endpoint (Opcional, caso necessário substituir servidor/proxy custom)
OPENROUTER_API_URL="https://openrouter.ai/api/v1/chat/completions"

# Qual modelo LLM utilizar do OpenRouter
LLM_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# Segredo para Autorização da Atualização via Cron (Automática na Vercel e manual localmente)
CRON_SECRET="segredo_local_teste"

# Chave (boolean flag) para usar o LLM ou apenas o resumo nativo do site
USE_LLM="true"

# Chave (boolean flag) para usar a biblioteca de tradução embutida no resumo/titulo final
USE_TRANSLATION="true"

# Configurações do Supabase (Obrigatório para banco de dados)
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_KEY="sua-chave-anon-publica-aqui"
