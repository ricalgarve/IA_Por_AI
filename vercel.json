{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-news",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/send-newsletter",
      "schedule": "5 9 * * *"
    }
  ]
}