{
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-news",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/update-news",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/update-news",
      "schedule": "8 22 * * *"
    },
    {
      "path": "/api/cron/update-news",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/send-newsletter",
      "schedule": "0 9 * * *"
    }
  ]
}